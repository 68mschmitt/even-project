    "pack": "npm run build && evenhub pack app.json dist -o even-starter.ehpk"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
