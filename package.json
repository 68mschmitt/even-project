{
  "name": "even-project",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.12.0 || >=22.13.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
